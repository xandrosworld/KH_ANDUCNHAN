# So Do Van Phuc frontend environment
# Copy to .env or .env.production before building.

# API mode:
# - Same domain shared hosting: leave empty, frontend calls /api/*.
# - API subdomain: set to https://api.sodovanphuc.vn, no trailing slash.
VITE_API_BASE_URL=

# Optional: Google Maps key for future map/heatmap work.
VITE_GOOGLE_MAPS_KEY=

# AI description/chat keys belong in backend/config/config.php as AI_GEMINI_KEY.
# Do not add VITE_* AI keys because frontend environment values are public.

# Kept for legacy imported services; not used in current SVP screens.
VITE_USD_VND_RATE=25000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_PAYPAL_CLIENT_ID=
