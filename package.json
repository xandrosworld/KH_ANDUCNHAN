{
  "name": "so-do-van-phuc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "contract:verify": "node scripts/verify-svp-contract.mjs",
    "php:parse": "node scripts/verify-php-syntax.mjs",
    "php:runtime": "powershell -ExecutionPolicy Bypass -File deploy/test-php-runtime.ps1 -RequirePhp",
    "php:runtime:optional": "powershell -ExecutionPolicy Bypass -File deploy/test-php-runtime.ps1",
    "ps:parse": "powershell -ExecutionPolicy Bypass -File scripts/verify-powershell-syntax.ps1",
    "config:verify:template": "powershell -ExecutionPolicy Bypass -File deploy/verify-hosting-config.ps1 -ConfigPath backend/config/config.example.php -AllowTemplate",
    "config:verify": "powershell -ExecutionPolicy Bypass -File deploy/verify-hosting-config.ps1",
    "config:dryrun": "powershell -ExecutionPolicy Bypass -File deploy/test-hosting-config-generator.ps1",
    "preview": "vite preview",
    "release": "powershell -ExecutionPolicy Bypass -File deploy/build-sodovanphuc-release.ps1",
    "release:verify": "powershell -ExecutionPolicy Bypass -File deploy/verify-sodovanphuc-release.ps1",
    "release:drill": "powershell -ExecutionPolicy Bypass -File deploy/test-release-upload-drill.ps1 -RequirePhp",
    "release:configured-dryrun": "powershell -ExecutionPolicy Bypass -File deploy/test-configured-upload-zip-dryrun.ps1 -RequirePhp",
    "preupload:report": "powershell -ExecutionPolicy Bypass -File deploy/preupload-report-sodovanphuc.ps1",
    "final:audit": "powershell -ExecutionPolicy Bypass -File deploy/final-prehosting-audit.ps1",
    "prehost:proof": "powershell -ExecutionPolicy Bypass -File deploy/run-prehosting-proof.ps1",
    "hosting:diagnose": "powershell -ExecutionPolicy Bypass -File deploy/diagnose-vanphuc-hosting.ps1",
    "hosting:cutover": "powershell -ExecutionPolicy Bypass -File deploy/domain-cutover-report-vanphuc.ps1",
    "hosting:cutover:ready": "powershell -ExecutionPolicy Bypass -File deploy/domain-cutover-report-vanphuc.ps1 -RequireReady",
    "hosting:browser": "powershell -ExecutionPolicy Bypass -File deploy/browser-smoke-vanphuc-hosting.ps1",
    "hosting:smoke": "powershell -ExecutionPolicy Bypass -File deploy/smoke-vanphuc-hosting.ps1",
    "hosting:smoke:write": "powershell -ExecutionPolicy Bypass -File deploy/smoke-vanphuc-hosting.ps1 -IncludeWriteWorkflow",
    "hosting:wait": "powershell -ExecutionPolicy Bypass -File deploy/wait-vanphuc-hosting-ready.ps1",
    "hosting:wait:write": "powershell -ExecutionPolicy Bypass -File deploy/wait-vanphuc-hosting-ready.ps1 -IncludeWriteWorkflow",
    "hosting:ready": "powershell -ExecutionPolicy Bypass -File deploy/ready-vanphuc-hosting.ps1",
    "hosting:ready:write": "powershell -ExecutionPolicy Bypass -File deploy/ready-vanphuc-hosting.ps1 -IncludeWriteWorkflow",
    "hosting:complete": "powershell -ExecutionPolicy Bypass -File deploy/complete-vanphuc-hosting-handoff.ps1 -IncludeWriteWorkflow",
    "hosting:complete:safe": "powershell -ExecutionPolicy Bypass -File deploy/complete-vanphuc-hosting-handoff.ps1",
    "hosting:acceptance": "powershell -ExecutionPolicy Bypass -File deploy/acceptance-report-vanphuc-hosting.ps1 -IncludeWriteWorkflow",
    "hosting:acceptance:safe": "powershell -ExecutionPolicy Bypass -File deploy/acceptance-report-vanphuc-hosting.ps1",
    "test:visual": "npx playwright test --config=playwright.config.ts",
    "qa": "npm run lint && npm run build && npm run test:visual",
    "prehost": "npm run php:parse && npm run ps:parse && npm run config:verify:template && npm run config:dryrun && npm run php:runtime:optional && npm run contract:verify && npm run qa && npm run release && npm run release:verify && npm run release:drill && npm run release:configured-dryrun"
  },
  "dependencies": {
    "@rjsf/core": "^6.6.2",
    "@rjsf/validator-ajv8": "^6.6.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.18.1",
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "php-parser": "^3.7.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
